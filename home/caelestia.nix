{ config, lib, pkgs, ... }:

{
  # ── Caelestia Shell ─────────────────────────────────────────
  programs.caelestia = {
    enable = true;
    cli.enable = true;
  };

  # Session-Variablen für Caelestia
  home.sessionVariables = {
    QS_DROP_EXPENSIVE_FONTS = "0";
  };

  # ── Kitty Theme Template ────────────────────────────────────
  # Wird von caelestia bei jedem scheme set befüllt
  home.file = {
    ".config/caelestia/templates/current-theme.conf".text = ''
      # Caelestia theme for Kitty
      # Auto-generated by caelestia user templates

      foreground #{{ onSurface.hex }}
      background #{{ surface.hex }}
      selection_foreground #{{ onSecondary.hex }}
      selection_background #{{ secondary.hex }}
      cursor #{{ secondary.hex }}
      cursor_text_color #{{ surface.hex }}

      color0 #{{ term0.hex }}
      color1 #{{ term1.hex }}
      color2 #{{ term2.hex }}
      color3 #{{ term3.hex }}
      color4 #{{ term4.hex }}
      color5 #{{ term5.hex }}
      color6 #{{ term6.hex }}
      color7 #{{ term7.hex }}
      color8 #{{ term8.hex }}
      color9 #{{ term9.hex }}
      color10 #{{ term10.hex }}
      color11 #{{ term11.hex }}
      color12 #{{ term12.hex }}
      color13 #{{ term13.hex }}
      color14 #{{ term14.hex }}
      color15 #{{ term15.hex }}
    '';

    ".config/caelestia/cli.json".text = builtins.toJSON {
      theme.postHook = "cp $HOME/.local/state/caelestia/theme/current-theme.conf $HOME/.config/kitty/current-theme.conf";
    };
  };
}
